<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="SO101">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import SO101 urdf file -->
    <xacro:include filename="$(find my_robot_description)/urdf/so101ws2.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="SO101.ros2_control.xacro" />


    <xacro:SO101_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
